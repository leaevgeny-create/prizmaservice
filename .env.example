# Database
DATABASE_URL="postgresql://prisma:prisma_secret@localhost:5432/prizmaservice?schema=public"
REDIS_URL="redis://localhost:6379"
MONGODB_URL="mongodb://prizmaservice:mongo_secret@localhost:27017/prizmaservice_geo"

# App
NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:3000

# Auth
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=change_me_refresh
REFRESH_TOKEN_EXPIRES_IN=30d

# File Storage (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=prizmaservice
S3_SECRET_KEY=minio_secret
S3_BUCKET=prizmaservice-files
S3_REGION=ru-central1

# Gosuslugi / ESIA
ESIA_CLIENT_ID=your_esia_client_id
ESIA_CLIENT_SECRET=your_esia_client_secret
ESIA_AUTH_URL=https://esia.gosuslugi.ru/aas/oauth2/ac
ESIA_TOKEN_URL=https://esia.gosuslugi.ru/aas/oauth2/te
ESIA_INFO_URL=https://esia.gosuslugi.ru/rs/prns

# Weather API
OPENWEATHER_API_KEY=your_openweather_key
YANDEX_WEATHER_API_KEY=your_yandex_weather_key

# Biometric
BIOAPI_URL=https://api.bioapi.ru
BIOAPI_KEY=your_bioapi_key

# EDS / CryptoPro
CRYPTOPRO_URL=https://ds.cryptopro.ru
CRYPTOPRO_KEY=your_cryptopro_key

# Payment
PAYMENT_GATEWAY_URL=https://api.tinkoff.ru/v2
PAYMENT_TERMINAL_KEY=your_terminal_key
PAYMENT_SECRET_KEY=your_payment_secret

# Email / SMS
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@prizmaservice.ru
SMTP_PASS=your_smtp_password
SMS_PROVIDER_URL=https://sms.ru/sms/send
SMS_API_KEY=your_sms_api_key
